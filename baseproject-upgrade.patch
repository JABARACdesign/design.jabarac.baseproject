+﻿using System.Collections.Generic;
+using Cysharp.Threading.Tasks;
+using JABARACdesign.Base.Application.Localization;
+using JABARACdesign.Base.Domain.Localization;
+
+namespace JABARACdesign.Base.Tests.Mock
+{
+    /// <summary>
+    /// テスト用のモックローカライズテーブルローダー。
+    /// 言語ごとにテーブルを事前登録できる。
+    /// </summary>
+    public class MockLocalizationTableLoader : ILocalizationTableLoader
+    {
+        private readonly Dictionary<LanguageCode, Dictionary<string, string>> _tables = new();
+        
+        /// <summary>
+        /// テスト用のテーブルを登録する。
+        /// </summary>
+        /// <param name="languageCode">言語コード</param>
+        /// <param name="table">キーと値のDictionary</param>
+        /// <returns>メソッドチェーン用にthisを返す</returns>
+        public MockLocalizationTableLoader WithTable(
+            LanguageCode languageCode,
+            Dictionary<string, string> table)
+        {
+            _tables[languageCode] = table;
+            return this;
+        }
+        
+        public UniTask<Dictionary<string, string>> LoadTableAsync(LanguageCode languageCode)
+        {
+            var table = _tables.TryGetValue(key: languageCode, value: out var t)
+                ? t
+                : new Dictionary<string, string>();
+            
+            return UniTask.FromResult(result: table);
+        }
+    }
+}
