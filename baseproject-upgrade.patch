+﻿using System;
+using System.Collections.Generic;
+using JABARACdesign.Base.Application.Localization;
+using JABARACdesign.Base.Domain.Localization;
+
+namespace JABARACdesign.Base.Tests.Mock
+{
+    /// <summary>
+    /// テスト用のモックローカライズサービス。
+    /// 辞書に登録されたキーと値を返す。
+    /// </summary>
+    public class MockLocalizationService : ILocalizationService
+    {
+        private readonly Dictionary<string, string> _table = new();
+        
+        public LanguageCode CurrentLanguage { get; private set; } = LanguageCode.Ja;
+        
+        public event Action<LanguageCode> OnLanguageChanged;
+        
+        /// <summary>
+        /// テスト用のローカライズテーブルにエントリを追加する。
+        /// </summary>
+        /// <param name="key">キー</param>
+        /// <param name="value">値</param>
+        /// <returns>メソッドチェーン用にthisを返す</returns>
+        public MockLocalizationService WithEntry(string key, string value)
+        {
+            _table[key] = value;
+            return this;
+        }
+        
+        public string GetText(string key)
+        {
+            return _table.TryGetValue(key: key, value: out var text) ? text : key;
+        }
+        
+        public string GetText(string key, params object[] args)
+        {
+            var template = GetText(key: key);
+            return string.Format(format: template, args: args);
+        }
+        
+        public void SetLanguage(LanguageCode languageCode)
+        {
+            CurrentLanguage = languageCode;
+            OnLanguageChanged?.Invoke(obj: languageCode);
+        }
+    }
+}
